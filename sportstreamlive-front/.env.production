#    Fly.io  : https://sportstreamlive-back.fly.dev
#    VPS     : https://api.tudominio.com
#
#  IMPORTANTE: sin barra al final de la URL.
#  IMPORTANTE: usa https:// (no http://) en producción.
# ══════════════════════════════════════════════════════════════

REACT_APP_API_URL=https://TU-URL-DEL-BACK-AQUI
REACT_APP_WS_URL=https://TU-URL-DEL-BACK-AQUI/ws
